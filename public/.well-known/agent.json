{
  "name": "AIロースト",
  "description": "プロフィールを入力するとAIが愛のある毒舌ツッコミ（ロースト）を生成するWebアプリ",
  "url": "https://ai-roast.ezoai.jp",
  "documentation": "https://ai-roast.ezoai.jp/llms.txt",
  "capabilities": {
    "mcp": {
      "endpoint": "https://ai-roast.ezoai.jp/api/mcp",
      "protocolVersion": "2024-11-05"
    }
  },
  "mcp": {
    "endpoint": "https://ai-roast.ezoai.jp/api/mcp",
    "protocol": "jsonrpc-2.0",
    "transport": "http-post",
    "authentication": "none",
    "tools": [
      {
        "name": "generate_roast",
        "description": "プロフィール情報からAIが愛のある毒舌ツッコミを生成する"
      }
    ]
  },
  "constraints": {
    "rateLimits": {
      "mcp": "10 requests per 10 minutes per IP"
    }
  },
  "provider": {
    "organization": "ezoai.jp",
    "url": "https://ezoai.jp"
  }
}
