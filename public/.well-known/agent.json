{
  "name": "AIロースト",
  "description": "プロフィールを入力するとAIが愛のある毒舌ツッコミ（ロースト）をしてくれるWebアプリ",
  "url": "https://ai-roast.ezoai.jp",
  "version": "1.0.0",
  "capabilities": {
    "streaming": false,
    "pushNotifications": false
  },
  "provider": {
    "organization": "Ghostfee",
    "url": "https://github.com/Michey0495"
  },
  "documentationUrl": "https://ai-roast.ezoai.jp/llms.txt",
  "authentication": {
    "schemes": ["none"]
  },
  "defaultInputModes": ["text"],
  "defaultOutputModes": ["text"],
  "protocols": {
    "mcp": {
      "endpoint": "https://ai-roast.ezoai.jp/api/mcp",
      "version": "2024-11-05",
      "tools": [
        {
          "name": "generate_roast",
          "description": "プロフィール情報からAIが愛のある毒舌ツッコミを生成する",
